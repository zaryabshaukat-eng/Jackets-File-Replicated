# Shopify Storefront API — copy to .env.local and fill in your values
# These VITE_-prefixed variables are required for the browser-side Storefront
# API client (artifacts/theme-preview/src/lib/shopify.ts) to connect at runtime.
# Only PUBLIC (read-only) Storefront tokens belong here — never admin or private tokens.

# Your myshopify.com domain, e.g. your-store.myshopify.com
VITE_PUBLIC_STORE_DOMAIN=

# Public Storefront API access token (Shopify Admin → Apps → Develop apps)
VITE_PUBLIC_STOREFRONT_API_TOKEN=

# Full Storefront GraphQL endpoint (auto-derived if left blank)
VITE_SHOPIFY_STOREFRONT_API_URL=

# Storefront ID shown in the Oxygen dashboard
VITE_PUBLIC_STOREFRONT_ID=

# Customer Account API (optional — needed for login/account flows)
VITE_PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
VITE_PUBLIC_CUSTOMER_ACCOUNT_API_URL=
