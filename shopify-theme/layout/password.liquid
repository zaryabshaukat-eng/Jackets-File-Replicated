<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: #0a0a0a;
      color: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
      text-align: center;
    }
    .pw-logo {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: #C8A96E;
      margin-bottom: 48px;
    }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 6vw, 72px);
      font-weight: 300;
      line-height: 1.1;
      margin-bottom: 20px;
    }
    p { font-size: 15px; color: rgba(255,255,255,.6); line-height: 1.7; margin-bottom: 36px; max-width: 480px; }
    .pw-form { display: flex; gap: 10px; width: 100%; max-width: 420px; }
    .pw-input {
      flex: 1;
      padding: 13px 18px;
      background: rgba(255,255,255,.07);
      border: 1.5px solid rgba(255,255,255,.15);
      border-radius: 4px;
      color: #fff;
      font-size: 14px;
      outline: none;
      transition: border-color .2s;
    }
    .pw-input:focus { border-color: #C8A96E; }
    .pw-input::placeholder { color: rgba(255,255,255,.4); }
    .pw-btn {
      padding: 13px 24px;
      background: #C8A96E;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      white-space: nowrap;
      transition: background .2s;
    }
    .pw-btn:hover { background: #DEC08A; }
    .pw-error { color: #f87171; font-size: 13px; margin-top: 12px; }
    .pw-admin { margin-top: 48px; font-size: 12px; color: rgba(255,255,255,.3); }
    .pw-admin a { color: rgba(255,255,255,.4); text-decoration: underline; }

    /* Background decorative circles */
    .deco { position: fixed; pointer-events: none; border-radius: 50%; }
    .deco--1 { width: 500px; height: 500px; background: rgba(200,169,110,.04); bottom: -150px; right: -100px; }
    .deco--2 { width: 300px; height: 300px; background: rgba(200,169,110,.03); top: -80px; left: -80px; }
  </style>
</head>
<body>
  <div class="deco deco--1"></div>
  <div class="deco deco--2"></div>

  <p class="pw-logo">Universal Jackets</p>
  <h1>Opening Soon</h1>
  <p>Premium outerwear, crafted for the bold. We're putting the finishing touches on something special — enter the password to get early access.</p>

  {%- form 'storefront_password' -%}
    <div class="pw-form">
      <input type="password" name="password" id="Password" class="pw-input" placeholder="Store password" autocomplete="current-password" required>
      <button type="submit" class="pw-btn">Enter</button>
    </div>
    {%- if form.errors -%}
      <p class="pw-error">Incorrect password. Please try again.</p>
    {%- endif -%}
  {%- endform -%}

  <p class="pw-admin">Are you the store owner? <a href="/admin" target="_blank">Log in here</a></p>

  {{ content_for_layout }}
</body>
</html>
