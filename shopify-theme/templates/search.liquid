<div class="search-results-page">
  <div class="page-hero">
    <div class="container">
      <p class="section-label">Search</p>
      <h1 class="page-hero__title">
        {%- if search.performed -%}
          Results for "{{ search.terms }}"
        {%- else -%}
          Search Products
        {%- endif -%}
      </h1>
      {%- if search.performed -%}
        <p class="page-hero__meta">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</p>
      {%- endif -%}
    </div>
  </div>
  <div class="container">
    <form action="{{ routes.search_url }}" method="get" class="search-results-page__form" role="search">
      <input type="hidden" name="type" value="product">
      <div class="search-results-page__input-wrap">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search jackets, styles, sizes…" class="search-results-page__input" autofocus aria-label="Search">
        <button type="submit" class="btn btn-primary">Search</button>
      </div>
    </form>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        <div class="products-grid" data-view="grid" style="margin-top:40px;">
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {%- render 'product-card', product: result -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="empty-state" style="margin-top:60px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <h2>No results found</h2>
          <p>Try different search terms or browse our full collection.</p>
          <a href="{{ shop.url }}/collections/all" class="btn btn-primary">Browse All Products</a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<style>
.search-results-page { padding-bottom: 80px; }
.search-results-page__form { margin-bottom: 0; }
.search-results-page__input-wrap { display: flex; gap: 12px; max-width: 640px; margin: 0 auto; }
.search-results-page__input { flex: 1; padding: 14px 20px; border: 1.5px solid var(--clr-light-border); border-radius: var(--radius-sm); font-size: 15px; color: var(--clr-black); outline: none; transition: border-color var(--transition-fast); }
.search-results-page__input:focus { border-color: var(--clr-black); }
</style>
