<div class="content-page">
  <div class="container" style="max-width:900px;padding-top:64px;padding-bottom:64px;min-height:60vh;">
    <nav class="breadcrumb" style="margin-bottom:32px;">
      <ul class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="{{ shop.url }}">Home</a></li>
        <li class="breadcrumb__item">/</li>
        <li class="breadcrumb__item breadcrumb__item--current">Contact</li>
      </ul>
    </nav>
    <p class="section-label" style="margin-bottom:12px;">Get In Touch</p>
    <h1 style="font-family:var(--font-serif);font-size:clamp(32px,4vw,52px);font-weight:400;margin-bottom:40px;line-height:1.2;">Contact Us</h1>

    <div class="contact-page__layout">
      <div>
        <div class="rte" style="font-size:15px;line-height:1.8;color:var(--clr-mid);max-width:720px;">
          <p>We'd love to hear from you. Whether it's a question about sizing, a custom order enquiry, or just a jacket-related chat — our team is here.</p>
          <p><strong>Response time:</strong> We aim to respond within 24 hours on business days.</p>
        </div>
        <div style="margin-top:40px;display:flex;flex-direction:column;gap:20px;">
          <div style="display:flex;gap:16px;">
            <span style="font-size:20px;">📍</span>
            <div>
              <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-muted);margin-bottom:2px;">Address</p>
              <p style="font-weight:500;">120 Mercer St, New York, NY 10012</p>
            </div>
          </div>
          <div style="display:flex;gap:16px;">
            <span style="font-size:20px;">📞</span>
            <div>
              <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-muted);margin-bottom:2px;">Phone</p>
              <p style="font-weight:500;">+1 (212) 555-0142</p>
            </div>
          </div>
          <div style="display:flex;gap:16px;">
            <span style="font-size:20px;">✉️</span>
            <div>
              <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-muted);margin-bottom:2px;">Email</p>
              <p style="font-weight:500;">hello@universaljackets.com</p>
            </div>
          </div>
          <div style="display:flex;gap:16px;">
            <span style="font-size:20px;">🕐</span>
            <div>
              <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-muted);margin-bottom:2px;">Hours</p>
              <p style="font-weight:500;">Mon–Fri 9am–6pm EST</p>
            </div>
          </div>
        </div>
      </div>

      <div>
        {%- form 'contact', id: 'ContactPageForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success" role="alert">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Message sent! We'll reply within 24 hours.
            </div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div class="form-field">
            <label for="cp-name" class="form-label">Name *</label>
            <input type="text" id="cp-name" name="contact[name]" required class="form-input" placeholder="Your name" autocomplete="name" value="{{ form.name }}">
          </div>
          <div class="form-field">
            <label for="cp-email" class="form-label">Email *</label>
            <input type="email" id="cp-email" name="contact[email]" required class="form-input" placeholder="you@email.com" autocomplete="email" value="{{ form.email }}">
          </div>
          <div class="form-field">
            <label for="cp-subject" class="form-label">Subject</label>
            <input type="text" id="cp-subject" name="contact[subject]" class="form-input" placeholder="Order enquiry, custom design…">
          </div>
          <div class="form-field">
            <label for="cp-msg" class="form-label">Message *</label>
            <textarea id="cp-msg" name="contact[body]" required class="form-textarea" rows="5" placeholder="How can we help?">{{ form.body }}</textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

<style>
  .contact-page__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 767px) {
    .contact-page__layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
