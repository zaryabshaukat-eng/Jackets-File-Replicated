<article class="article-page" itemscope itemtype="https://schema.org/BlogPosting">
  <meta itemprop="datePublished" content="{{ article.published_at | date: '%Y-%m-%d' }}">
  <meta itemprop="author" content="{{ article.author }}">

  <!-- Article Hero -->
  <div class="article-page__hero">
    {%- if article.image -%}
      <img
        src="{{ article.image | img_url: '1400x600', crop: 'center' }}"
        srcset="{{ article.image | img_url: '800x400', crop: 'center' }} 800w, {{ article.image | img_url: '1400x600', crop: 'center' }} 1400w"
        sizes="100vw"
        alt="{{ article.title | escape }}"
        loading="eager"
        class="article-page__hero-img"
        itemprop="image">
    {%- endif -%}
    <div class="article-page__hero-content">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol class="breadcrumb__list">
            <li class="breadcrumb__item"><a href="{{ shop.url }}">Home</a></li>
            <li class="breadcrumb__item" aria-hidden="true">/</li>
            <li class="breadcrumb__item"><a href="{{ blog.url }}">{{ blog.title }}</a></li>
            <li class="breadcrumb__item" aria-hidden="true">/</li>
            <li class="breadcrumb__item" aria-current="page">{{ article.title }}</li>
          </ol>
        </nav>
        <div class="article-page__meta">
          <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
          {%- if article.author -%}<span>· by {{ article.author }}</span>{%- endif -%}
          {%- if article.tags.size > 0 -%}
            <span>·</span>
            {%- for tag in article.tags -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-page__tag">{{ tag }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <h1 class="article-page__title" itemprop="headline">{{ article.title }}</h1>
      </div>
    </div>
  </div>

  <!-- Article Body -->
  <div class="container">
    <div class="article-page__body">
      <div class="article-page__content rte" itemprop="articleBody">
        {{ article.content }}
      </div>

      <!-- Share -->
      <div class="article-page__share">
        <span>Share:</span>
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url | url_encode }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>

      <!-- Related articles -->
      {%- if blog.articles.size > 1 -%}
        <div class="article-page__related">
          <h2 class="section-title">More from the Journal</h2>
          <div class="blog-grid blog-grid--3">
            {%- for related_article in blog.articles limit: 3 -%}
              {%- unless related_article.handle == article.handle -%}
                <article class="blog-article-card">
                  {%- if related_article.image -%}
                    <a href="{{ related_article.url }}" class="blog-article-card__img-wrap">
                      <img src="{{ related_article.image | img_url: '600x400', crop: 'center' }}" alt="{{ related_article.title | escape }}" loading="lazy" class="blog-article-card__img">
                    </a>
                  {%- endif -%}
                  <div class="blog-article-card__body">
                    <time>{{ related_article.published_at | date: '%b %d, %Y' }}</time>
                    <h3 class="blog-article-card__title"><a href="{{ related_article.url }}">{{ related_article.title }}</a></h3>
                    <a href="{{ related_article.url }}" class="blog-article-card__link">Read →</a>
                  </div>
                </article>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</article>
