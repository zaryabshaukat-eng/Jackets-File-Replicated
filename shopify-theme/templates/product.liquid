{% assign product = product %}

<article itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="description" content="{{ product.description | strip_html | escape }}">
  {%- if product.featured_image -%}
    <meta itemprop="image" content="{{ product.featured_image | image_url: width: 800 }}">
  {%- endif -%}

  <script data-product-variants type="application/json">
    {{ product.variants | json }}
  </script>

  <div class="container">
    <!-- Breadcrumb + Back Button row -->
    <div class="product-page__topbar">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb__list">
          <li class="breadcrumb__item"><a href="{{ shop.url }}">Home</a></li>
          <li class="breadcrumb__item" aria-hidden="true">/</li>
          {%- if collection -%}
            <li class="breadcrumb__item"><a href="{{ collection.url }}">{{ collection.title }}</a></li>
            <li class="breadcrumb__item" aria-hidden="true">/</li>
          {%- else -%}
            <li class="breadcrumb__item"><a href="{{ shop.url }}/collections/all">Jackets</a></li>
            <li class="breadcrumb__item" aria-hidden="true">/</li>
          {%- endif -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ product.title }}</li>
        </ol>
      </nav>
      <a href="{%- if collection -%}{{ collection.url }}{%- else -%}{{ shop.url }}/collections/all{%- endif -%}" class="btn-back-products">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Products
      </a>
    </div>
  </div>

  <!-- Main layout -->
  <div class="container">
    <div class="pdp-layout">

      <!-- Left: Image Gallery -->
      <div class="pdp-images">
        <div class="pdp-images__main" id="productGalleryMain">
          {%- for image in product.images -%}
            <div class="product-gallery-main__item {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" style="position:absolute;inset:0;display:none;">
              <img
                src="{{ image | image_url: width: 1000, height: 1200, crop: 'center' }}"
                srcset="{{ image | image_url: width: 600, height: 720, crop: 'center' }} 600w, {{ image | image_url: width: 1000, height: 1200, crop: 'center' }} 1000w"
                sizes="(max-width: 768px) 100vw, 50vw"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                style="width:100%;height:100%;object-fit:cover;display:block;"
                itemprop="image">
            </div>
          {%- else -%}
            <div class="product-gallery-main__item is-active" style="position:absolute;inset:0;">
              <div style="width:100%;height:100%;background:var(--clr-bg-soft);"></div>
            </div>
          {%- endfor -%}

          <!-- Sale/New badge -->
          {%- if product.compare_at_price > product.price -%}
            {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            <span class="badge badge--sale" style="position:absolute;top:16px;left:16px;z-index:2;">-{{ discount_pct }}%</span>
          {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
            <span class="badge badge--new" style="position:absolute;top:16px;left:16px;z-index:2;">New</span>
          {%- endif -%}

          <!-- Gallery nav arrows -->
          {%- if product.images.size > 1 -%}
            <button class="gallery-arrow gallery-arrow--prev" id="galleryPrev" aria-label="Previous image">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="gallery-arrow gallery-arrow--next" id="galleryNext" aria-label="Next image">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="pdp-images__thumbs" id="productGalleryThumbs">
            {%- for image in product.images -%}
              <button class="pdp-thumb {% if forloop.first %}pdp-thumb--active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ image | image_url: width: 150, height: 150, crop: 'center' }}" alt="{{ image.alt | default: product.title | escape }}" loading="lazy" width="150" height="150" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: Product Info -->
      <div class="pdp-info">
        {%- if product.vendor -%}
          <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-gold);margin-bottom:8px;">{{ product.vendor }}</p>
        {%- elsif product.type != blank -%}
          <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--clr-gold);margin-bottom:8px;">{{ product.type }}</p>
        {%- endif -%}

        <h1 class="pdp-title" itemprop="name">{{ product.title }}</h1>

        <!-- Rating display -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
          <span class="pdp-stars" aria-label="4.6 out of 5 stars">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if i <= 4 %}#C8A96E{% else %}none{% endif %}" stroke="#C8A96E" stroke-width="1.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            {%- endfor -%}
          </span>
          <span style="font-size:13px;color:var(--clr-muted);">4.6 ({{ product.metafields.reviews.rating_count | default: '47' }} reviews)</span>
        </div>

        <!-- Price -->
        <div class="pdp-price-row" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <link itemprop="availability" href="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
          <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
          {%- if product.compare_at_price > product.price -%}
            {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            <span class="pdp-price pdp-price--sale" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">{{ product.price | money }}</span>
            <span class="pdp-price pdp-price--compare">{{ product.compare_at_price | money }}</span>
            <span class="pdp-save-badge">Save {{ save_pct }}%</span>
          {%- else -%}
            <span class="pdp-price" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">{{ product.price | money }}</span>
          {%- endif -%}
        </div>

        <!-- Description excerpt -->
        <p style="font-size:14px;line-height:1.7;color:var(--clr-mid);margin-bottom:28px;max-width:480px;">
          {%- if product.description != blank -%}
            {{ product.description | strip_html | truncate: 240 }}
          {%- else -%}
            A premium jacket designed for those who demand both style and substance. Crafted from high-quality materials, this piece delivers exceptional warmth, a tailored silhouette, and lasting durability — season after season.
          {%- endif -%}
        </p>

        <!-- Add to Cart Form -->
        {%- form 'product', product, id: 'AddToCartForm', data-product-form: '' -%}
          <input type="hidden" name="id" id="selectedVariantId" value="{{ product.selected_or_first_available_variant.id }}">

          {%- for option in product.options_with_values -%}
            <div class="pdp-option-group" data-option-index="{{ forloop.index0 }}">
              {%- if option.name == 'Color' or option.name == 'Colour' -%}
                <div class="pdp-option-label">
                  <span>Colour</span>
                  <span class="pdp-selected-value" id="selected-{{ option.name | downcase | replace: ' ', '-' }}">{{ option.selected_value }}</span>
                </div>
                <div class="pdp-color-swatches" role="group" aria-label="{{ option.name }} options">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="pdp-color-swatch{% if option.selected_value == value %} pdp-color-swatch--active{% endif %}"
                      data-option="{{ forloop.parentloop.index0 }}"
                      data-value="{{ value | escape }}"
                      title="{{ value }}"
                      aria-label="{{ value }}"
                      aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                      style="background:{{ value | downcase | replace: ' ', '' }};">
                    </button>
                  {%- endfor -%}
                </div>

              {%- elsif option.name == 'Size' -%}
                <div class="pdp-option-label">
                  <span>Size</span>
                  <span class="pdp-selected-value" id="selected-{{ option.name | downcase }}">{{ option.selected_value }}</span>
                  <a href="{{ shop.url }}/pages/size-guide" style="font-size:12px;color:var(--clr-gold);margin-left:auto;text-decoration:underline;">Size Guide</a>
                </div>
                <div class="pdp-size-btns" role="group" aria-label="{{ option.name }} options">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="pdp-size-btn{% if option.selected_value == value %} pdp-size-btn--active{% endif %}"
                      data-option="{{ forloop.parentloop.index0 }}"
                      data-value="{{ value | escape }}"
                      aria-label="Size {{ value }}"
                      aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>

              {%- else -%}
                <div class="pdp-option-label">
                  <span>{{ option.name }}</span>
                  <span class="pdp-selected-value" id="selected-{{ option.name | downcase | replace: ' ', '-' }}">{{ option.selected_value }}</span>
                </div>
                <div class="product-option__select-wrap">
                  <select class="form-input product-option__select" data-option="{{ forloop.index0 }}" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}

          <!-- Validation error placeholder -->
          <div class="pdp-error" id="pdpError" role="alert" style="display:none;margin-bottom:16px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span id="pdpErrorMsg"></span>
          </div>

          <!-- Quantity + Add to Cart row -->
          <div style="display:flex;gap:12px;align-items:stretch;margin-top:4px;margin-bottom:0;">
            <div class="pdp-qty">
              <button type="button" id="qtyMinus" aria-label="Decrease quantity">−</button>
              <span id="qtyDisplay">1</span>
              <button type="button" id="qtyPlus" aria-label="Increase quantity">+</button>
              <input type="hidden" name="quantity" id="productQty" value="1">
            </div>
            <button type="submit" name="add" class="btn btn-primary pdp-cart-btn" id="addToCartBtn" {% unless product.available %}disabled aria-disabled="true"{% endunless %}>
              <span class="btn-addtocart__text" style="display:inline-flex;align-items:center;gap:8px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
              </span>
              <span class="btn-addtocart__loading" hidden>
                <span class="spinner"></span>
              </span>
            </button>
          </div>

          <!-- Cart success message -->
          <div class="cart-success" id="cartSuccess" hidden role="alert" style="margin-top:12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Added to cart! <a href="{{ routes.cart_url }}">View Cart →</a>
          </div>
        {%- endform -%}

        <!-- Trust Badges -->
        <div class="pdp-trust">
          <div class="pdp-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free shipping over $120</span>
          </div>
          <div class="pdp-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
            <span>7-day returns</span>
          </div>
          <div class="pdp-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            <span>Secure payment</span>
          </div>
        </div>

        <!-- Accordions -->
        <div class="pdp-accordion">
          <details class="pdp-accordion__item">
            <summary class="pdp-accordion__trigger">
              Product Details
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="pdp-accordion__body">
              {%- if product.description != blank -%}
                {{ product.description | strip_html | truncate: 400 }}
              {%- else -%}
                Premium jacket with expert construction, quality hardware, and a tailored silhouette. Features inner lining, reinforced seams, and multiple pockets.
              {%- endif -%}
            </div>
          </details>

          <details class="pdp-accordion__item">
            <summary class="pdp-accordion__trigger">
              Sizing &amp; Fit
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="pdp-accordion__body">
              This style fits true to size. If you're between sizes, we recommend sizing up for a relaxed fit. See our <a href="{{ shop.url }}/pages/size-guide">Size Guide</a> for detailed measurements. Model is 6'1" wearing size L.
            </div>
          </details>

          <details class="pdp-accordion__item">
            <summary class="pdp-accordion__trigger">
              Shipping &amp; Returns
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="pdp-accordion__body">
              Free shipping on orders over $120. Standard delivery 5–8 business days. Express available at checkout. Returns accepted within 7 days — unworn, tags attached. See full <a href="{{ shop.url }}/pages/shipping">Shipping Policy</a> and <a href="{{ shop.url }}/pages/returns">Returns Policy</a>.
            </div>
          </details>

          <details class="pdp-accordion__item">
            <summary class="pdp-accordion__trigger">
              Care Instructions
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="pdp-accordion__body">
              Spot clean where possible. Dry clean recommended for leather styles. For puffer jackets, machine wash on gentle cold cycle and tumble dry low with 2 clean tennis balls.
            </div>
          </details>
        </div>
      </div>
    </div><!-- /.pdp-layout -->

    <!-- Customer Reviews -->
    <div class="pdp-reviews">
      <div class="pdp-reviews__header">
        <h2 style="font-family:var(--font-serif);font-size:32px;font-weight:400;">Customer Reviews</h2>
        <div style="display:flex;align-items:center;gap:12px;margin-top:8px;">
          <span class="pdp-stars" aria-label="4.6 out of 5 stars">
            {%- for i in (1..5) -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="{% if i <= 4 %}#C8A96E{% else %}none{% endif %}" stroke="#C8A96E" stroke-width="1.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            {%- endfor -%}
          </span>
          <span style="font-size:15px;color:var(--clr-muted);">4.6 out of 5 · 47 reviews</span>
        </div>
      </div>
      <div class="pdp-reviews__grid">
        {%- assign reviews = "James K.,5,June 2025,Absolutely love this jacket. The quality is exceptional — fits perfectly and looks even better in person.|Priya M.,5,May 2025,Worth every penny. I've been searching for a jacket like this for years. The material feels premium and the stitching is flawless.|Carlos R.,4,May 2025,Great jacket, very warm and stylish. Sizing runs slightly small so I went up one size — perfect fit.|Sophie L.,5,April 2025,Second jacket I've bought from Universal Jackets. Both are incredible. Will definitely be back for a third." | split: "|" -%}
        {%- for review in reviews -%}
          {%- assign parts = review | split: "," -%}
          <div class="pdp-review-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
              <div>
                <p style="font-weight:600;font-size:14px;">{{ parts[0] }}</p>
                <p style="font-size:12px;color:var(--clr-muted);">{{ parts[2] }}</p>
              </div>
              <span class="pdp-stars">
                {%- assign rating = parts[1] | times: 1 -%}
                {%- for i in (1..5) -%}
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="{% if i <= rating %}#C8A96E{% else %}none{% endif %}" stroke="#C8A96E" stroke-width="1.5">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                {%- endfor -%}
              </span>
            </div>
            <p style="font-size:14px;line-height:1.65;color:var(--clr-mid);">{{ parts[3] }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Related Products -->
    <div class="pdp-related">
      <p class="section-label">You May Also Like</p>
      <h2 class="section-title" style="margin-bottom:32px;">Related Jackets</h2>
      <div class="pdp-related__grid">
        {%- assign related_collection = product.collections.first -%}
        {%- assign shown_related = 0 -%}
        {%- if related_collection -%}
          {%- for related_product in related_collection.products limit: 5 -%}
            {%- if related_product.id != product.id and shown_related < 4 -%}
              {%- render 'product-card', product: related_product -%}
              {%- assign shown_related = shown_related | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if shown_related == 0 -%}
          {%- for p in collections.all.products limit: 5 -%}
            {%- if p.id != product.id and shown_related < 4 -%}
              {%- render 'product-card', product: p -%}
              {%- assign shown_related = shown_related | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- Bottom Back Button -->
    <div style="text-align:center;padding-top:48px;">
      <a href="{%- if collection -%}{{ collection.url }}{%- else -%}{{ shop.url }}/collections/all{%- endif -%}" class="btn-back-products btn-back-products--lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to All Products
      </a>
    </div>

  </div><!-- /.container -->
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "description": {{ product.description | strip_html | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": "{{ product.price | divided_by: 100.0 }}",
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": "{{ shop.url }}{{ product.url }}"
  }
}
</script>

<script>
(function() {
  // Wire up custom pdp-qty buttons to the hidden input
  var minus = document.getElementById('qtyMinus');
  var plus  = document.getElementById('qtyPlus');
  var display = document.getElementById('qtyDisplay');
  var input   = document.getElementById('productQty');
  if (minus && plus && input) {
    minus.addEventListener('click', function() {
      var v = Math.max(1, parseInt(input.value) - 1);
      input.value = v;
      if (display) display.textContent = v;
    });
    plus.addEventListener('click', function() {
      var v = Math.min(10, parseInt(input.value) + 1);
      input.value = v;
      if (display) display.textContent = v;
    });
  }

  // Wire pdp-color-swatch / pdp-size-btn to update selected label + variant
  document.querySelectorAll('.pdp-color-swatch, .pdp-size-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var optIdx = btn.dataset.option;
      var val    = btn.dataset.value;
      var isSwatch = btn.classList.contains('pdp-color-swatch');
      var selector = isSwatch ? '.pdp-color-swatch' : '.pdp-size-btn';
      // reset siblings in same group
      var group = btn.closest('.pdp-option-group');
      if (group) {
        group.querySelectorAll(selector).forEach(function(b) {
          b.classList.remove(isSwatch ? 'pdp-color-swatch--active' : 'pdp-size-btn--active');
          b.setAttribute('aria-pressed', 'false');
        });
      }
      btn.classList.add(isSwatch ? 'pdp-color-swatch--active' : 'pdp-size-btn--active');
      btn.setAttribute('aria-pressed', 'true');
      // Update label
      var label = group && group.querySelector('.pdp-selected-value');
      if (label) label.textContent = val;
      // find variant
      findAndSetVariant();
    });
  });

  var variants = [];
  var variantScript = document.querySelector('[data-product-variants]');
  if (variantScript) { try { variants = JSON.parse(variantScript.textContent); } catch(e) {} }
  var selectedOptions = {};

  function findAndSetVariant() {
    // collect selections
    document.querySelectorAll('.pdp-option-group').forEach(function(group, idx) {
      var active = group.querySelector('.pdp-color-swatch--active, .pdp-size-btn--active');
      if (active) selectedOptions[idx] = active.dataset.value;
      var sel = group.querySelector('.product-option__select');
      if (sel) selectedOptions[idx] = sel.value;
    });
    if (!variants.length) return;
    var match = variants.find(function(v) {
      return Object.entries(selectedOptions).every(function(e) {
        return v.options[parseInt(e[0])] === e[1];
      });
    });
    var variantInput = document.getElementById('selectedVariantId');
    var addBtn = document.getElementById('addToCartBtn');
    var btnText = addBtn && addBtn.querySelector('.btn-addtocart__text');
    if (match && variantInput) {
      variantInput.value = match.id;
      if (addBtn) { addBtn.disabled = !match.available; addBtn.setAttribute('aria-disabled', String(!match.available)); }
      if (btnText) {
        btnText.innerHTML = match.available
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>Add to Cart'
          : 'Sold Out';
      }
    }
  }

  // select change
  document.querySelectorAll('.product-option__select').forEach(function(sel) {
    sel.addEventListener('change', findAndSetVariant);
  });
})();
</script>
