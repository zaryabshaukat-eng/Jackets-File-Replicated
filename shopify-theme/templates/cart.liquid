<div style="padding: 64px 0; min-height: 60vh;">
  <div class="container" style="max-width: 900px;">

    <nav style="font-size:12px; opacity:.6; margin-bottom:32px;">
      <a href="{{ shop.url }}">Home</a>
      <span style="margin:0 8px;">/</span>
      <span>Cart</span>
    </nav>

    <h1 style="font-family:var(--font-serif); font-size:clamp(32px,4vw,52px); font-weight:400; margin-bottom:40px; line-height:1.2;">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div style="display:grid; grid-template-columns:1fr 360px; gap:48px; align-items:start;" class="cart-page__layout">

        <!-- Line items -->
        <div>
          {%- for item in cart.items -%}
            <div style="display:flex; gap:24px; padding:24px 0; border-bottom:1px solid var(--clr-light-border); align-items:start;">

              <!-- Thumbnail -->
              <a href="{{ item.url }}" style="flex-shrink:0;">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | image_url: width: 200, height: 240, crop: 'center' }}"
                    alt="{{ item.title | escape }}"
                    width="100"
                    height="120"
                    loading="lazy"
                    style="width:100px; height:120px; object-fit:cover; border-radius:6px; display:block;">
                {%- else -%}
                  <div style="width:100px; height:120px; background:linear-gradient(160deg,#1a1a2e,#0d0d1a); border-radius:6px;"></div>
                {%- endif -%}
              </a>

              <!-- Item details -->
              <div style="flex:1;">
                <h3 style="font-family:var(--font-serif); font-size:20px; font-weight:400; margin-bottom:6px;">
                  <a href="{{ item.url }}" style="color:var(--clr-black);">{{ item.product.title }}</a>
                </h3>
                <p style="font-size:13px; color:var(--clr-muted); margin-bottom:12px;">
                  {%- unless item.product.has_only_default_variant -%}
                    {{ item.variant.title }}
                  {%- endunless -%}
                  {%- for option in item.options_with_values -%}
                    {%- if option.name == 'Size' -%}Size: {{ option.value }}{%- endif -%}
                    {%- if option.name == 'Color' %} · Color: {{ option.value }}{%- endif -%}
                  {%- endfor -%}
                </p>

                <!-- Qty stepper + remove -->
                <div style="display:flex; align-items:center; gap:16px;">
                  <div style="display:flex; align-items:center; border:1px solid var(--clr-light-border); border-radius:4px;">
                    <form action="{{ routes.cart_change_url }}" method="post" style="display:contents;">
                      <input type="hidden" name="id" value="{{ item.variant_id }}">
                      <input type="hidden" name="quantity" value="{{ item.quantity | minus: 1 }}">
                      <button type="submit" style="padding:6px 12px; border:none; background:none; cursor:pointer; font-size:18px; line-height:1;" aria-label="Decrease quantity">−</button>
                    </form>
                    <span style="padding:6px 16px; border-left:1px solid var(--clr-light-border); border-right:1px solid var(--clr-light-border); font-size:14px;">{{ item.quantity }}</span>
                    <form action="{{ routes.cart_change_url }}" method="post" style="display:contents;">
                      <input type="hidden" name="id" value="{{ item.variant_id }}">
                      <input type="hidden" name="quantity" value="{{ item.quantity | plus: 1 }}">
                      <button type="submit" style="padding:6px 12px; border:none; background:none; cursor:pointer; font-size:18px; line-height:1;" aria-label="Increase quantity">+</button>
                    </form>
                  </div>
                  <a href="{{ routes.cart_change_url }}?id={{ item.variant_id }}&quantity=0" style="background:none; border:none; cursor:pointer; font-size:12px; color:var(--clr-muted); text-decoration:underline;">Remove</a>
                </div>
              </div>

              <!-- Line price -->
              <p style="font-weight:600; font-family:var(--font-serif); font-size:18px; flex-shrink:0;">{{ item.line_price | money }}</p>

            </div>
          {%- endfor -%}

          <div style="margin-top:32px;">
            <a href="{{ shop.url }}/collections/all" class="btn btn-outline">Continue Shopping</a>
          </div>
        </div>

        <!-- Order summary sidebar -->
        <div style="background:var(--clr-bg-soft); padding:32px; border-radius:8px; position:sticky; top:calc(var(--announcement-h) + var(--header-h) + 24px);">
          <h2 style="font-family:var(--font-serif); font-size:22px; font-weight:400; margin-bottom:24px;">Order Summary</h2>

          <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px;">
            <span style="color:var(--clr-muted);">Subtotal</span>
            <span style="font-weight:500;">{{ cart.total_price | money }}</span>
          </div>

          <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px;">
            <span style="color:var(--clr-muted);">Shipping</span>
            <span style="font-weight:500;">
              {%- if cart.total_price >= 12000 -%}
                Free
              {%- else -%}
                Calculated at checkout
              {%- endif -%}
            </span>
          </div>

          <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px;">
            <span style="color:var(--clr-muted);">Tax (est.)</span>
            <span style="font-weight:500;">Calculated at checkout</span>
          </div>

          <div style="border-top:2px solid var(--clr-black); margin-top:16px; padding-top:16px; display:flex; justify-content:space-between; font-weight:700; font-size:16px;">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <a href="{{ routes.checkout }}" class="btn btn-primary btn-full" style="margin-top:24px; display:flex; align-items:center; justify-content:center; gap:8px;">
            Proceed to Checkout
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>

          <div style="margin-top:16px; text-align:center; font-size:12px; color:var(--clr-muted);">🔒 Secure checkout — SSL encrypted</div>
        </div>

      </div>

    {%- else -%}

      <!-- Empty cart state -->
      <div style="text-align:center; padding:80px 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="opacity:.3; margin-bottom:24px;"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <h2 style="font-family:var(--font-serif); font-size:28px; font-weight:400; margin-bottom:12px;">Your cart is empty</h2>
        <p style="color:var(--clr-muted); margin-bottom:32px;">Looks like you haven't added anything yet.</p>
        <a href="{{ shop.url }}/collections/all" class="btn btn-primary" style="display:inline-flex;">Start Shopping</a>
      </div>

    {%- endif -%}
  </div>
</div>

<style>
@media (max-width: 900px) {
  .cart-page__layout { grid-template-columns: 1fr !important; }
}
</style>
