<div class="auth-page">
  <div class="auth-page__split">
    <!-- Left decorative panel -->
    <div class="auth-page__deco" aria-hidden="true">
      <div class="auth-page__deco-inner">
        <span class="auth-deco__logo">UNIVERSAL JACKETS</span>
        <p class="auth-deco__quote">"Outerwear that moves with you."</p>
        <div class="auth-deco__shapes">
          <div class="auth-deco__circle auth-deco__circle--1"></div>
          <div class="auth-deco__circle auth-deco__circle--2"></div>
          <div class="auth-deco__circle auth-deco__circle--3"></div>
        </div>
      </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-page__form-panel">
      <div class="auth-page__form-inner">
        <a href="{{ shop.url }}" class="auth-page__back" aria-label="Back to store">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Back to Store
        </a>

        <h1 class="auth-page__title">Welcome Back</h1>
        <p class="auth-page__sub">Sign in to your account to track orders and manage your details.</p>

        {%- form 'customer_login', id: 'CustomerLoginForm' -%}
          {%- if form.errors -%}
            <div class="form-error" role="alert">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="form-field">
            <label for="CustomerEmail" class="form-label">Email address</label>
            <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" class="form-input" placeholder="you@example.com" required {% if form.email %}value="{{ form.email }}"{% endif %}>
          </div>

          <div class="form-field">
            <div class="form-label-row">
              <label for="CustomerPassword" class="form-label">Password</label>
              <a href="{{ routes.account_recover_url }}" class="form-forgot">Forgot password?</a>
            </div>
            <div class="form-input-group">
              <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" class="form-input" placeholder="••••••••" required>
              <button type="button" class="form-input-toggle" id="togglePassword" aria-label="Show/hide password">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Sign In</button>
        {%- endform -%}

        <div class="auth-page__divider"><span>or</span></div>

        <p class="auth-page__switch">
          Don't have an account?
          <a href="{{ routes.account_register_url }}" class="auth-page__switch-link">Create account</a>
        </p>
      </div>
    </div>
  </div>
</div>
