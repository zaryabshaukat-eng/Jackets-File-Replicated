<div class="auth-page">
  <div class="auth-page__split">
    <!-- Left decorative panel — matches React: background linear-gradient(160deg,#0d1a2a,#0a0a0a) -->
    <div class="auth-page__deco" aria-hidden="true" style="background:linear-gradient(160deg,#0d1a2a,#0a0a0a);">
      <div class="auth-page__deco-inner">
        <span class="auth-deco__logo">UNIVERSAL JACKETS</span>
        <p class="auth-deco__quote">"Join the community of bold dressers."</p>
        <div class="auth-deco__shapes">
          <div class="auth-deco__circle auth-deco__circle--1"></div>
          <div class="auth-deco__circle auth-deco__circle--2"></div>
          <div class="auth-deco__circle auth-deco__circle--3"></div>
        </div>
      </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-page__form-panel">
      <div class="auth-page__form-inner">
        <a href="{{ shop.url }}" class="auth-page__back">← Back to store</a>

        <h1 class="auth-page__title">Create Account</h1>
        <p class="auth-page__sub">Join Universal Jackets for exclusive access.</p>

        {%- form 'create_customer', id: 'CreateCustomerForm' -%}
          {%- if form.errors -%}
            <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-field">
              <label for="FirstName" class="form-label">First Name</label>
              <input type="text" name="customer[first_name]" id="FirstName" autocomplete="given-name" class="form-input" value="{{ form.first_name }}" required>
            </div>
            <div class="form-field">
              <label for="LastName" class="form-label">Last Name</label>
              <input type="text" name="customer[last_name]" id="LastName" autocomplete="family-name" class="form-input" value="{{ form.last_name }}" required>
            </div>
          </div>

          <div class="form-field">
            <label for="Email" class="form-label">Email</label>
            <input type="email" name="customer[email]" id="Email" autocomplete="email" class="form-input" value="{{ form.email }}" required>
          </div>

          <div class="form-field">
            <label for="CreatePassword" class="form-label">Password</label>
            <input type="password" name="customer[password]" id="CreatePassword" autocomplete="new-password" class="form-input" placeholder="Min 8 characters" required>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Create Account</button>
        {%- endform -%}

        <p style="text-align:center; margin-top:24px; font-size:13px; color:var(--clr-muted);">
          Already have an account? <a href="{{ routes.account_login_url }}" style="color:var(--clr-gold);">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>
