{% schema %}
{
  "name": "Blog Preview",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Our Journal" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Style guides, care tips, and stories from behind the seams." },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "image_picker", "id": "side_image", "label": "Side Image" }
  ]
}
{% endschema %}

<section class="blog-preview section-spacing" data-aos="fade-up">
  <div class="container">
    <div class="blog-preview__inner">
      <!-- Image side -->
      <div class="blog-preview__image-col">
        {%- if section.settings.side_image -%}
          <img
            src="{{ section.settings.side_image | img_url: '800x1000', crop: 'center' }}"
            alt="Journal"
            class="blog-preview__img"
            loading="lazy"
            width="800"
            height="1000"
          >
        {%- else -%}
          <div class="blog-preview__img-placeholder"></div>
        {%- endif -%}
        <div class="blog-preview__image-badge">
          <span>Since 2015</span>
        </div>
      </div>

      <!-- Content side -->
      <div class="blog-preview__content-col">
        <p class="section-label">Journal</p>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p class="blog-preview__sub">{{ section.settings.subheading }}</p>

        <div class="blog-preview__articles">
          {%- assign blog_handle = section.settings.blog.handle | default: 'journal' -%}
          {%- assign blog_obj = blogs[blog_handle] -%}
          {%- if blog_obj.articles.size > 0 -%}
            {%- for article in blog_obj.articles limit: 3 -%}
              <article class="blog-card">
                {%- if article.image -%}
                  <a href="{{ article.url }}" class="blog-card__img-wrap" tabindex="-1" aria-hidden="true">
                    <img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.title | escape }}" loading="lazy" class="blog-card__img">
                  </a>
                {%- endif -%}
                <div class="blog-card__body">
                  <p class="blog-card__meta">{{ article.published_at | date: "%B %d, %Y" }}</p>
                  <h3 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                  <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
                  <a href="{{ article.url }}" class="blog-card__link">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- assign sample_titles = "How to Style a Bomber Jacket This Season,The Art of Leather Care: A Complete Guide,New Season Drop — What's In Store" | split: "," -%}
            {%- for title in sample_titles -%}
              <article class="blog-card">
                <div class="blog-card__body">
                  <p class="blog-card__meta">{{ 'now' | date: "%B %Y" }}</p>
                  <h3 class="blog-card__title">{{ title }}</h3>
                  <p class="blog-card__excerpt">Explore our latest insights on outerwear, style, and the craft behind every Universal Jacket piece.</p>
                  <a href="{{ shop.url }}/blogs/journal" class="blog-card__link">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <a href="{{ shop.url }}/blogs/{{ blog_handle }}" class="btn btn-outline">
          View All Articles
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
