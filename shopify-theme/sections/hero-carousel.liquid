{% schema %}
{
  "name": "Hero Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Premium Outerwear" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Crafted for every season" },
        { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Shop Now" },
        { "type": "url",  "id": "cta_url",  "label": "Button Link" },
        { "type": "select", "id": "text_color", "label": "Text Color", "options": [{"value":"light","label":"Light"},{"value":"dark","label":"Dark"}], "default": "light" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        { "type": "slide", "settings": { "heading": "New Season. New Edge.", "subheading": "Premium jackets crafted for the bold", "cta_text": "Explore Collection" } },
        { "type": "slide", "settings": { "heading": "Built to Last", "subheading": "From street to summit — outerwear that moves with you", "cta_text": "Shop Now" } },
        { "type": "slide", "settings": { "heading": "Custom Your Jacket", "subheading": "Design your own statement piece", "cta_text": "Design Yours" } }
      ]
    }
  ]
}
{% endschema %}

<section class="hero-carousel" id="heroCarousel" aria-label="Featured collection">
  <div class="hero-carousel__track" id="heroTrack">
    {%- for block in section.blocks -%}
      <div class="hero-carousel__slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="hero-carousel__bg">
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 1600, height: 900, crop: 'center' }}"
              srcset="{{ block.settings.image | image_url: width: 800, height: 450, crop: 'center' }} 800w, {{ block.settings.image | image_url: width: 1200, height: 675, crop: 'center' }} 1200w, {{ block.settings.image | image_url: width: 1600, height: 900, crop: 'center' }} 1600w"
              sizes="100vw"
              alt="{{ block.settings.heading | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              class="hero-carousel__img"
            >
          {%- else -%}
            <div class="hero-carousel__placeholder" style="background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0d0d0d 100%);"></div>
          {%- endif -%}
          <div class="hero-carousel__overlay"></div>
        </div>
        <div class="hero-carousel__content text-{{ block.settings.text_color | default: 'light' }}">
          <p class="hero-carousel__eyebrow reveal-text">Universal Jackets</p>
          <h1 class="hero-carousel__heading reveal-text">{{ block.settings.heading }}</h1>
          <p class="hero-carousel__sub reveal-text">{{ block.settings.subheading }}</p>
          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.cta_url | default: shop.url | append: '/collections/all' }}" class="hero-carousel__cta reveal-text">
              {{ block.settings.cta_text }}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Controls -->
  {%- if section.blocks.size > 1 -%}
    <button class="hero-carousel__arrow hero-carousel__arrow--prev" id="heroPrev" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="hero-carousel__arrow hero-carousel__arrow--next" id="heroNext" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="hero-carousel__dots" role="tablist" aria-label="Carousel slides">
      {%- for block in section.blocks -%}
        <button class="hero-carousel__dot {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}" role="tab" aria-label="Slide {{ forloop.index }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Scroll indicator -->
  <div class="hero-scroll-indicator" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero-scroll-indicator__line"></div>
  </div>
</section>
