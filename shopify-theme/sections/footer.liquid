{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer Logo" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Universal Jackets — premium outerwear, made to be worn." },
    { "type": "text", "id": "address", "label": "Address", "default": "120 Mercer St, New York, NY 10012" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 (212) 555-0142" },
    { "type": "text", "id": "email", "label": "Email", "default": "digitalsolutionsunctx@gmail.com" },
    { "type": "text", "id": "instagram", "label": "Instagram URL" },
    { "type": "text", "id": "facebook", "label": "Facebook URL" },
    { "type": "text", "id": "tiktok", "label": "TikTok URL" },
    { "type": "text", "id": "pinterest", "label": "Pinterest URL" }
  ]
}
{% endschema %}

<!-- Trust Bar -->
<div class="footer-trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="trust-bar__text">
          <strong>FREE DELIVERY</strong>
          <span>on all orders over $120</span>
        </div>
      </div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
        </div>
        <div class="trust-bar__text">
          <strong>7 DAYS RETURN</strong>
          <span>If goods have problems</span>
        </div>
      </div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        </div>
        <div class="trust-bar__text">
          <strong>SECURE PAYMENT</strong>
          <span>100% secure payment</span>
        </div>
      </div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="trust-bar__text">
          <strong>24/7 SUPPORT</strong>
          <span>Dedicated support</span>
        </div>
      </div>
    </div>
  </div>
</div>

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__top">
      <!-- Brand Column -->
      <div class="site-footer__brand">
        {%- if section.settings.logo -%}
          <img src="{{ section.settings.logo | image_url: width: 280 }}" alt="{{ shop.name }}" width="140" loading="lazy">
        {%- else -%}
          <span class="footer-logo-text">UNIVERSAL JACKETS</span>
        {%- endif -%}
        <p class="footer-tagline">{{ section.settings.tagline }}</p>
        <address class="footer-contact">
          {%- if section.settings.address != blank -%}
            <p>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ section.settings.address }}
            </p>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <p>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.27 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.59a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
            </p>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <p>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </p>
          {%- endif -%}
        </address>
        <!-- Social links -->
        <div class="footer-social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest != blank -%}
            <a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.14 1.22-5.14s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.23-.87 3.47-.25 1.04.52 1.87 1.54 1.87 1.84 0 3.08-2.37 3.08-5.16 0-2.13-1.44-3.62-3.5-3.62-2.39 0-3.79 1.79-3.79 3.64 0 .72.28 1.49.62 1.91.07.08.08.15.06.24l-.23.95c-.04.15-.13.18-.3.11C7.7 13.69 7 11.95 7 10.45c0-2.97 2.16-5.7 6.23-5.7 3.27 0 5.81 2.33 5.81 5.45 0 3.26-2.05 5.88-4.9 5.88-.96 0-1.86-.5-2.17-1.09l-.59 2.21c-.21.82-.79 1.84-1.18 2.47.89.27 1.83.42 2.8.42 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Quick Links -->
      <div class="site-footer__links-col">
        <h3 class="footer-col__title">Customer Support</h3>
        <ul class="footer-links">
          <li><a href="{{ shop.url }}/pages/contact">Contact</a></li>
          <li><a href="{{ shop.url }}/pages/shipping">Shipping</a></li>
          <li><a href="{{ shop.url }}/pages/returns">Returns</a></li>
          <li><a href="{{ routes.account_url }}">My Account</a></li>
          <li><a href="{{ shop.url }}/pages/faq">FAQ</a></li>
        </ul>
      </div>

      <div class="site-footer__links-col">
        <h3 class="footer-col__title">Quick Links</h3>
        <ul class="footer-links">
          <li><a href="{{ shop.url }}/collections/new-in">New In</a></li>
          <li><a href="{{ shop.url }}/collections/bestsellers">Bestsellers</a></li>
          <li><a href="{{ shop.url }}/pages/lookbook">Lookbook</a></li>
          <li><a href="{{ shop.url }}/blogs/journal">Journal</a></li>
        </ul>
      </div>

      <div class="site-footer__links-col">
        <h3 class="footer-col__title">Explore</h3>
        <ul class="footer-links">
          <li><a href="{{ shop.url }}/pages/about">About</a></li>
          <li><a href="{{ shop.url }}/blogs/journal">Journal</a></li>
          <li><a href="{{ shop.url }}/pages/custom-design">Custom Design</a></li>
          <li><a href="{{ shop.url }}/pages/size-guide">Size Guide</a></li>
          <li><a href="{{ shop.url }}/pages/wholesale">Wholesale</a></li>
        </ul>
      </div>
    </div>

    <!-- Payment badges & bottom bar -->
    <div class="site-footer__bottom">
      <p class="footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-payment">
        {{ powered_by_link }}
      </div>
      <div class="footer-legal">
        <a href="{{ shop.url }}/pages/privacy">Privacy</a>
        <a href="{{ shop.url }}/pages/terms">Terms</a>
        <a href="{{ shop.url }}/pages/returns">Refunds</a>
      </div>
    </div>
  </div>
</footer>
