{% schema %}
{
  "name": "Marquee Products",
  "settings": [
    { "type": "text", "id": "heading_1", "label": "Featured Row Heading", "default": "Featured Products" },
    { "type": "collection", "id": "featured_collection", "label": "Featured Collection" },
    { "type": "text", "id": "heading_2", "label": "New Arrivals Row Heading", "default": "New Arrivals" },
    { "type": "collection", "id": "new_collection", "label": "New Arrivals Collection" }
  ]
}
{% endschema %}

<section class="marquee-section section-spacing" data-aos="fade-up">
  <div class="container">
    <div class="section-header">
      <p class="section-label">{{ section.settings.heading_1 }}</p>
      <h2 class="section-title">Featured Products</h2>
    </div>
  </div>

  <!-- Marquee Row 1: Left to Right -->
  <div class="marquee-wrapper" aria-label="{{ section.settings.heading_1 }}">
    <div class="marquee-track marquee-track--ltr" id="marquee1">
      {%- assign featured = collections[section.settings.featured_collection.handle] | default: collections.all -%}
      {%- for product in featured.products limit: 10 -%}
        {%- render 'product-card', product: product, card_class: 'marquee-card' -%}
      {%- endfor -%}
      {%- for product in featured.products limit: 10 -%}
        {%- render 'product-card', product: product, card_class: 'marquee-card' -%}
      {%- endfor -%}
      {%- if featured.products.size == 0 -%}
        {%- for i in (1..6) -%}
          <div class="product-card marquee-card product-card--placeholder">
            <div class="product-card__image-wrap"><div class="product-card__placeholder-img"></div></div>
            <div class="product-card__info">
              <p class="product-card__title">Featured Jacket {{ i }}</p>
              <p class="product-card__price">$189.00</p>
            </div>
          </div>
          <div class="product-card marquee-card product-card--placeholder">
            <div class="product-card__image-wrap"><div class="product-card__placeholder-img"></div></div>
            <div class="product-card__info">
              <p class="product-card__title">Featured Jacket {{ i }}</p>
              <p class="product-card__price">$189.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <div class="container" style="margin-top:64px;">
    <div class="section-header">
      <p class="section-label">{{ section.settings.heading_2 }}</p>
      <h2 class="section-title">New Arrivals</h2>
    </div>
  </div>

  <!-- Marquee Row 2: Right to Left -->
  <div class="marquee-wrapper" aria-label="{{ section.settings.heading_2 }}">
    <div class="marquee-track marquee-track--rtl" id="marquee2">
      {%- assign new_col = collections[section.settings.new_collection.handle] | default: collections.all -%}
      {%- for product in new_col.products limit: 10 -%}
        {%- render 'product-card', product: product, card_class: 'marquee-card' -%}
      {%- endfor -%}
      {%- for product in new_col.products limit: 10 -%}
        {%- render 'product-card', product: product, card_class: 'marquee-card' -%}
      {%- endfor -%}
      {%- if new_col.products.size == 0 -%}
        {%- for i in (1..6) -%}
          <div class="product-card marquee-card product-card--placeholder">
            <div class="product-card__image-wrap"><div class="product-card__placeholder-img"></div></div>
            <div class="product-card__info">
              <p class="product-card__title">New Arrival {{ i }}</p>
              <p class="product-card__price">$159.00</p>
            </div>
          </div>
          <div class="product-card marquee-card product-card--placeholder">
            <div class="product-card__image-wrap"><div class="product-card__placeholder-img"></div></div>
            <div class="product-card__info">
              <p class="product-card__title">New Arrival {{ i }}</p>
              <p class="product-card__price">$159.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
